{
  "type": "module",
  "name": "scribe-quickstart",
  "version": "1.0.0",
  "description": "Zoom AI Scribe API Quickstart",
  "main": "dist/index.js",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "format": "prettier --write src/*.ts",
    "start": "npm run build && node dist/index.js",
    "start:compiled": "node dist/index.js",
    "playground": "cd playground && npm run dev",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "author": "Zoom Video Communications, Inc.",
  "contributors": [
    {
      "name": "EkaanshArora"
    }
  ],
  "license": "ISC",
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "express": "^4.22.1",
    "jsrsasign": "^11.1.1",
    "multer": "^2.1.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsrsasign": "^10.5.15",
    "@types/multer": "^1.4.13",
    "@types/node": "^24.12.0",
    "@types/supertest": "^7.2.0",
    "prettier": "^3.8.1",
    "supertest": "^7.2.2",
    "typescript": "^5.9.3",
    "vitest": "^4.1.1"
  }
}

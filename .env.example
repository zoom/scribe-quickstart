# Zoom API credentials
ZOOM_API_KEY=
ZOOM_API_SECRET=

# AWS credentials — injected into every batch job request
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=

# S3 bucket paths (trailing slash required)
S3_INPUT_URI=s3://your-bucket/

# Default language for transcription
LANGUAGE=en-US

# Webhook for batch job notifications
WEBHOOK_URL=
WEBHOOK_SECRET=

PORT=4000
